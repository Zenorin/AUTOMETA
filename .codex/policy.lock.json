      "bundles": [
        "data-pipeline"
      ]
    },
    {
      "name": "collectors",
      "path": "packages/collectors",
      "module_type": "crawler-session",
      "bundles": [
        "crawler-session"
      ]
    },
    {
      "name": "reference-analysis",
      "path": "tools/reference-analysis",
